# Dockerfile to replicate the 'teleop' environment on Ubuntu 20.04 (ARM64/Jetson)
# Fully offline: no apt-get needed, all shared libraries are pre-copied from the host.
FROM arm64v8/ubuntu:20.04

ENV DEBIAN_FRONTEND=noninteractive

# ─── System shared libraries (pre-copied from host, no network needed) ──────
COPY system_libs/ /usr/local/lib/
RUN ldconfig

# ─── Create unitree user (preserves exact absolute paths for editable installs)
RUN useradd -m -s /bin/bash -G video,plugdev unitree

# ─── teleop conda environment ───────────────────────────────────────────────
RUN mkdir -p /home/unitree/.local/share/mamba/envs/teleop && \
    chown -R unitree:unitree /home/unitree/.local
COPY --chown=unitree:unitree teleop_env.tar.gz /tmp/
RUN tar -xzf /tmp/teleop_env.tar.gz -C /home/unitree/.local/share/mamba/envs/teleop && \
    rm /tmp/teleop_env.tar.gz

COPY --chown=unitree:unitree local_site_packages.tar.gz /tmp/
RUN tar -xzf /tmp/local_site_packages.tar.gz -C /home/unitree/.local/share/mamba/envs/teleop/lib/python3.8/ && \
    rm /tmp/local_site_packages.tar.gz

COPY --chown=unitree:unitree PyQt5.tar.gz /tmp/
RUN tar -xzf /tmp/PyQt5.tar.gz -C /home/unitree/.local/share/mamba/envs/teleop/lib/python3.8/site-packages/ && \
    rm /tmp/PyQt5.tar.gz

# ─── ROS 2 Offline Dependencies ─────────
USER root
RUN mkdir -p /opt/ros/foxy
COPY ros_foxy.tar.gz /tmp/
RUN tar -xzf /tmp/ros_foxy.tar.gz -C /opt/ros/foxy --strip-components=1 && \
    rm /tmp/ros_foxy.tar.gz

USER unitree
RUN mkdir -p /home/unitree/project/public/unitree_ros2
COPY --chown=unitree:unitree unitree_ros2_ws.tar.gz /tmp/
RUN tar -xzf /tmp/unitree_ros2_ws.tar.gz -C /home/unitree/project/public/unitree_ros2 --strip-components=1 && \
    rm /tmp/unitree_ros2_ws.tar.gz && \
    find /home/unitree/project/public/unitree_ros2/install -type f -name "*.bash" -o -name "*.sh" -o -name "*.zsh" | xargs sed -i '/cyclonedds_ws/d' && \
    find /home/unitree/project/public/unitree_ros2/install -type f -path "*/share/ament_index/resource_index/parent_prefix_path/*" | xargs sed -i 's|/home/unitree/cyclonedds_ws/install/rmw_cyclonedds_cpp:||g; s|/home/unitree/unitree_ros2/cyclonedds_ws/install/.*:||g'

# ─── External dependency: unitree_sdk2_python (editable install) ─────────
RUN mkdir -p /home/unitree/project && chown unitree:unitree /home/unitree/project
COPY --chown=unitree:unitree unitree_sdk2_python.tar.gz /tmp/
RUN tar -xzf /tmp/unitree_sdk2_python.tar.gz -C /home/unitree/project && \
    rm /tmp/unitree_sdk2_python.tar.gz

# ─── XRoboToolkit OrinVideoSender ───────────────────────────────────────────
COPY --chown=unitree:unitree XRoboToolkit-Orin-Video-Sender/ /home/unitree/tools/XRoboToolkit-Orin-Video-Sender/
RUN chmod +x /home/unitree/tools/XRoboToolkit-Orin-Video-Sender/OrinVideoSender && \
    chmod +x /home/unitree/tools/XRoboToolkit-Orin-Video-Sender/open_image_sender.sh

# ─── inspire_hand_sdk (editable install of inspire_sdkpy) ────────────────────
COPY --chown=unitree:unitree inspire_hand_sdk/ /home/unitree/tools/inspire_hand_ws/inspire_hand_sdk/

# ─── Fix editable install paths ───────────────────────────────────────────────
USER root
RUN find /home/unitree/.local/share/mamba/envs/teleop/lib/python3.8/site-packages/ -type f \( -name "*.pth" -o -name "*.json" -o -name "*.py" -o -name "*.txt" \) -exec sed -i 's|/home/unitree/project/ANY2Humanoid|/home/unitree/project/OmniClone-release|g' {} +

# ─── OmniClone-release project ──────────
USER unitree
COPY --chown=unitree:unitree . /home/unitree/project/OmniClone-release


# ─── Environment ────────────────────────────────────────────────────────────
ENV PATH="/usr/local/lib:/home/unitree/.local/share/mamba/envs/teleop/bin:$PATH"
ENV LD_LIBRARY_PATH="/usr/local/lib:${LD_LIBRARY_PATH}"
ENV GST_PLUGIN_PATH="/usr/local/lib/gstreamer-1.0"
ENV RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
ENV LD_PRELOAD=/usr/local/lib/libgomp.so.1

USER unitree
WORKDIR /home/unitree/project/OmniClone-release

CMD ["bash"]
